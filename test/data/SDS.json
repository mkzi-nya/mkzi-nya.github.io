{
  "title": "抑郁自评量表(SDS)",
  "description": "抑郁自评量表(Self-Rating Depression Scale, SDS)是由Zung编制的用于评估抑郁症状严重程度的量表。该量表包含20个项目。",
  "instruction": "下面有20个问题，请仔细阅读每一条，根据您最近一周的实际感受选择适当选项。该问卷用于帮助您了解自己的抑郁水平。",
  "timeLimit": 10,
  "defaultQuestionType": "radio",
  "defaultOptions": [
    {"text": "没有或很少时间", "score": 1},
    {"text": "有时", "score": 2},
    {"text": "经常", "score": 3},
    {"text": "总是或几乎总是", "score": 4}
  ],
  "questions": [
    {"id": 1, "text": "我觉得闷闷不乐，情绪低沉", "type": "radio", "reverse": false},
    {"id": 2, "text": "我觉得一天之中早晨最好", "type": "radio", "reverse": true},
    {"id": 3, "text": "我要哭或想哭", "type": "radio", "reverse": false},
    {"id": 4, "text": "我晚上睡眠不好", "type": "radio", "reverse": false},
    {"id": 5, "text": "我吃得跟平常一样多", "type": "radio", "reverse": true},
    {"id": 6, "text": "我与异性密切接触时和以往一样感到愉快", "type": "radio", "reverse": true},
    {"id": 7, "text": "我发觉我的体重在减轻", "type": "radio", "reverse": false},
    {"id": 8, "text": "我有便秘的苦恼", "type": "radio", "reverse": false},
    {"id": 9, "text": "我心跳比平时快", "type": "radio", "reverse": false},
    {"id": 10, "text": "我无故感到疲乏", "type": "radio", "reverse": false},
    {"id": 11, "text": "我的头脑跟平常一样清楚", "type": "radio", "reverse": true},
    {"id": 12, "text": "我觉得做事情跟平常一样容易", "type": "radio", "reverse": true},
    {"id": 13, "text": "我觉得不安而平静不下来", "type": "radio", "reverse": false},
    {"id": 14, "text": "我对未来抱有希望", "type": "radio", "reverse": true},
    {"id": 15, "text": "我比平常更容易生气激动", "type": "radio", "reverse": false},
    {"id": 16, "text": "我觉得做出决定是容易的", "type": "radio", "reverse": true},
    {"id": 17, "text": "我觉得自己是个有用的人，有人需要我", "type": "radio", "reverse": true},
    {"id": 18, "text": "我的生活过得很有意思", "type": "radio", "reverse": true},
    {"id": 19, "text": "我认为如果我死了别人会生活得好些", "type": "radio", "reverse": false},
    {"id": 20, "text": "我跟平常一样喜欢做事情", "type": "radio", "reverse": true}
  ],
  "scoring": {
    "method": "custom",
    "description": "计算总分后乘以1.25得到标准分"
  },
  "interpretation": [
    {
      "min": 25,
      "max": 52,
      "level": "正常范围",
      "description": "您的抑郁水平在正常范围内，没有明显的抑郁症状。",
      "suggestions": ["保持积极的生活态度", "继续保持健康的生活方式", "适当进行放松活动"]
    },
    {
      "min": 53,
      "max": 62,
      "level": "轻度抑郁",
      "description": "您的抑郁水平为轻度。可能表现出轻微的情绪低落和兴趣减退。",
      "suggestions": ["增加户外活动和运动", "保持规律的作息时间", "与朋友家人多交流", "必要时寻求心理咨询"]
    },
    {
      "min": 63,
      "max": 75,
      "level": "中度抑郁",
      "description": "您的抑郁水平为中度。抑郁症状较为明显，可能影响日常生活和工作。",
      "suggestions": ["寻求专业心理医生的帮助", "考虑进行心理治疗", "必要时使用抗抑郁药物", "定期监测症状变化"]
    },
    {
      "min": 76,
      "max": 100,
      "level": "重度抑郁",
      "description": "您的抑郁水平为重度。严重影响生活质量，可能伴随自杀念头。",
      "suggestions": ["立即寻求专业精神科医生的帮助", "可能需要住院治疗", "定期接受心理治疗", "密切关注自杀风险"]
    }
  ]
}
